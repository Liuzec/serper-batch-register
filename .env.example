# ============================================
# Serper 批量注册工具 - 配置文件模板
# 复制为 .env 后填入你自己的值
# ============================================

# ============================================
# 方案选择（二选一）
# ============================================
# api    — 默认方案，轮换 5 个临时邮箱 API（1secmail/tempmail.lol/mail.gw/mail.tm/guerrilla）
#           无需额外配置，开箱即用，~40+ 个不同邮箱域名
# domain — 自建域名池方案，需要自有域名 + Cloudflare 配置
#           更稳定可控，但需要购买域名并配置
EMAIL_MODE=api

# ============================================
# 必填：验证码服务
# ============================================
# Capsolver API Key (用于解 reCAPTCHA + Turnstile 验证码)
# 注册: https://capsolver.com  充值后获取
CAPSOLVER_API_KEY=你的Capsolver_API_Key

# ============================================
# 必填：代理（推荐 IPRoyal）
# ============================================
# IPRoyal 旋转代理（推荐！每次注册自动换 IP，防封）
# 注册: https://iproyal.com  购买 Residential Proxies
IPROYAL_USER=你的IPRoyal用户名
IPROYAL_PASS=你的IPRoyal密码

# 备选: 固定代理（所有请求走同一 IP，容易被封，不推荐）
# PROXY_URL=http://127.0.0.1:7897

# ============================================
# 自建域名池配置（仅 EMAIL_MODE=domain 时需要）
# ============================================
# 多个域名逗号分隔，域名越多越安全
# 例: CUSTOM_EMAIL_DOMAIN=mysite.xyz,mysite.uk,another.org
# 需要: 域名 + Cloudflare Email Routing + Worker + KV
# 详细配置方法见 技术思路说明.md
CUSTOM_EMAIL_DOMAIN=你的域名.xyz
CF_ACCOUNT_ID=你的Cloudflare账号ID
CF_API_TOKEN=你的Cloudflare_API_Token
CF_KV_NAMESPACE_ID=你的KV命名空间ID

# 每个域名在时间窗口内最多注册几个号 (默认 3)
# DOMAIN_MAX_PER_WINDOW=3

# 时间窗口秒数, 默认 1800 (30 分钟)
# DOMAIN_WINDOW_SECONDS=1800

# ============================================
# 通用频率控制（可选调优）
# ============================================

# 两次注册之间的最小间隔秒数, 默认 0 (不限制)
# 设为 5-10 可降低被检测风险
# REGISTER_INTERVAL=0

# ============================================
# 其他（一般不需要改）
# ============================================

# 最大并发数, 默认 5
# MAX_CONCURRENCY=5

# API Key 保存路径, 默认 api_keys.json
# OUTPUT_FILE=api_keys.json
